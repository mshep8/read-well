# PostgreSQL connection for the learn2read database.
# Use either DATABASE_URL or the PG* variables below.
# Create the database first: createdb learn2read
# Then run: psql learn2read -f db/learn2read_creation.sql
# Then run: psql learn2read -f db/lear2read_data.sql

DATABASE_URL=postgresql://localhost:5432/learn2read

# If your local PostgreSQL requires a login, set these as needed.
PGHOST=localhost
PGPORT=5432
PGDATABASE=learn2read
PGUSER=postgres
PGPASSWORD=password
